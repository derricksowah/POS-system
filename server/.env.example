# Server
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pos_db
DB_USER=pos_user
DB_PASSWORD=your_secure_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# CORS
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Hidden Maintenance Accounts
# Developer-only accounts for post-deployment updates and maintenance
# These accounts are hidden from the admin dashboard and user management
# Leave empty to disable hidden accounts
HIDDEN_ADMIN_PASSWORD=your_secure_dev_admin_password
HIDDEN_CASHIER_PASSWORD=your_secure_dev_cashier_password
